<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Premium off-white gradient background -->
    <gradient
        android:angle="270"
        android:startColor="#FDFEFE"
        android:endColor="#F4F7F5"
        android:type="linear" />
    <!-- Golden elegant border -->
    <stroke
        android:width="4dp"
        android:color="#D4AF37" />
    <!-- Rounded corners of 20dp as requested -->
    <corners android:radius="20dp" />
</shape>
